# ==========================================================================
# Root .gitignore for the Crew repo (contains the CrewAssignment RN app)
# Patterns without a leading slash match at any depth, so these also cover
# everything inside CrewAssignment/. The app keeps its own .gitignore too.
# ==========================================================================

# --- OS / editor ---------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
*.swp
*~
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# --- Node / JS -----------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# --- Environment / secrets ----------------------------------------------
.env
.env.*
!.env.example
*.pem
*.p8
*.p12
*.mobileprovision
google-services.json
GoogleService-Info.plist

# --- React Native / Metro -----------------------------------------------
.metro-health-check*
*.jsbundle
metro.log

# --- iOS / Xcode ---------------------------------------------------------
ios/build/
build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.xcuserstate
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
**/.xcode.env.local

# --- CocoaPods / Ruby ----------------------------------------------------
**/Pods/
/vendor/bundle/
**/vendor/bundle/

# --- Android / Gradle / IntelliJ ----------------------------------------
.gradle/
local.properties
*.hprof
.cxx/
.kotlin/
*.keystore
!debug.keystore
captures/

# --- Testing / coverage --------------------------------------------------
coverage/
/coverage

# --- fastlane ------------------------------------------------------------
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# --- Misc ----------------------------------------------------------------
*.log
*.tgz
.tmp/
tmp/
